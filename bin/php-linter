#!/usr/bin/env php
<?php

/**
 * PHP Linter and Metrics Analyzer Execution Script.
 *
 * Scans the current repository for PHP files and performs static analysis
 * and linting checks. It first runs metrics analysis to evaluate code quality
 * indicators, followed by linting to enforce coding standards.
 *
 * ## Preconditions
 * - Must be run from the repository root directory to correctly locate `vendor/autoload.php` and configuration files.
 *
 * ## Arguments
 * --fix    Sort composer.json and package.json files into conventional order.
 *          When this flag is set, only sorting is performed and all other checks are skipped.
 *
 * @example
 * ```bash
 * # Execute from the repository root
 * php bin/php-linter
 *
 * # Sort JSON files
 * php bin/php-linter --fix
 * ```
 */

declare(strict_types=1);

use DouglasGreen\PhpLinter\ComposerChecker;
use DouglasGreen\PhpLinter\Config;
use DouglasGreen\PhpLinter\DocStandardsChecker;
use DouglasGreen\PhpLinter\IgnoreList;
use DouglasGreen\PhpLinter\IssueHolder;
use DouglasGreen\PhpLinter\Linter\ComposerFile;
use DouglasGreen\PhpLinter\Linter\Linter;
use DouglasGreen\PhpLinter\Linter\UnusedClassAnalyzer;
use DouglasGreen\PhpLinter\Linter\UnusedFunctionAnalyzer;
use DouglasGreen\PhpLinter\Metrics\Analyzer;
use DouglasGreen\PhpLinter\Metrics\CacheManager;
use DouglasGreen\PhpLinter\Metrics\MetricChecker;
use DouglasGreen\PhpLinter\PackageJsonChecker;
use DouglasGreen\PhpLinter\Repository;

$currentDir = getcwd();
if ($currentDir === false) {
    throw new Exception('Unable to get working dir');
}

require_once $currentDir . '/vendor/autoload.php';

// Parse command-line arguments
$fixMode = in_array('--fix', $argv, true);

// Load configuration
$config = new Config($currentDir);
$ignoreIssues = $config->getIgnoreIssues();

// Create issue holder for collecting issues
$issueHolder = new IssueHolder();
$issueHolder->setIgnoreIssues($ignoreIssues);

$repository = new Repository();
$phpFiles = $repository->getPhpFiles();
$ignoreList = new IgnoreList($currentDir);

// 1. Run Metrics
$cache = new CacheManager($currentDir);
$analyzer = new Analyzer($currentDir, $cache, $ignoreList, $config, $issueHolder);
$analyzer->run($phpFiles);

// 2. Run Linter
$composerFile = new ComposerFile($currentDir . '/composer.json');
$linter = new Linter($composerFile, $ignoreList, $issueHolder);
$linter->run($phpFiles);

// 3. Run Unused Class Analyzer
$unusedClassAnalyzer = new UnusedClassAnalyzer($issueHolder, $ignoreList);
$unusedClassAnalyzer->run($phpFiles);

// 4. Run Unused Function Analyzer
$unusedFunctionAnalyzer = new UnusedFunctionAnalyzer($issueHolder, $ignoreList);
$unusedFunctionAnalyzer->run($phpFiles);

// 5. Run Composer Checker
$composerChecker = new ComposerChecker($currentDir, $issueHolder, '', $fixMode);
$composerChecker->run();

// 6. Run Package.json Checker
$packageChecker = new PackageJsonChecker($currentDir, $issueHolder, '', $fixMode);
$packageChecker->run();

// If in fix mode, skip remaining checks
if ($fixMode) {
    echo "JSON files have been sorted.\n";
    exit(0);
}

// 7. Run Doc Standards Checker
$docChecker = new DocStandardsChecker($currentDir, $issueHolder, $ignoreList);
$docChecker->run();

// Print all collected issues
$issueHolder->printIssues();

